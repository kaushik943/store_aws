SECRET_KEY=replace-with-a-long-random-secret
DATABASE_TYPE=dynamodb

# Local frontend -> backend proxy target
VITE_BACKEND_URL=http://localhost:8000

# Local + deployed frontend origins allowed by FastAPI
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://ak-store-rxl.vercel.app

# Optional for OTP email sending through AWS SES. If blank, OTP prints in backend logs during local dev.
SES_FROM_EMAIL=
SES_CONFIGURATION_SET=

# Optional AWS credentials for local development if your shell/profile does not already provide them.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
